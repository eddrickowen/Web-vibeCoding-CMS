# Copy this file to .env and fill in your values

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/meridian-cms

# Secret key for Payload (generate a long random string, keep it private)
PAYLOAD_SECRET=change-this-to-a-long-random-secret-string

# Your deployed CMS URL (used for CORS — set this in Vercel environment variables too)
SERVER_URL=https://your-cms.vercel.app

# Your deployed frontend URL (used for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Vercel Blob storage token — get this from Vercel dashboard after adding Blob storage.
# Leave empty for local development (media will be stored in public/media instead).
BLOB_READ_WRITE_TOKEN=
