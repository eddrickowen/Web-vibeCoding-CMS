# Copy this file to .env and fill in your values

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/meridian-cms

# Secret key for Payload (generate a random string, keep it private)
PAYLOAD_SECRET=change-this-to-a-long-random-secret-string

# Server port (admin panel will be at http://localhost:PORT/admin)
PORT=3001
